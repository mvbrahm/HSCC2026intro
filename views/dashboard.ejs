<!DOCTYPE html>
<html>
  <head>
    <!-- Including head partial -->
    <%- include('./partials/head') -%>
  </head>
  <body>
    <%- include('./partials/navmenu') -%>
    <div class="container">

    <h1> Hello, <%= name %> </h1>
    <h3> Email: <%= email %> </h3>

    <button id="emailupdate-toggle"> Change Email</button>
    <br>
    <!-- Basic form -->
    <form method="POST" id="emailupdate" style="display: none;">
        <label for="email"> New Email:</label>
        <input type="email" id="email" name="email">
        <button type="submit"> Update Email </button>
    </form>
    <br>







    <button id="contrast-toggle">Contrast Boost</button>
  </div> <!-- end containter -->
  <script src="/javascripts/togglescript.js" ></script>
  <script src="/javascripts/toggleemail.js" ></script>
  </body>
</html>